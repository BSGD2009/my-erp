// BoxERP — Prisma Schema
// Session 4 Review: 7 new tables (PaymentTerm, ShipToAddress, MaterialType,
//   WorkCenterType, Equipment, Operation, EquipmentCapability, SupplierContact).
//   Replaced MaterialType + WorkCenterType enums with admin-managed lookup tables.
//   Split addresses, payment terms FK, equipment tracking, operations catalog.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CSR
}

enum ContactType {
  MAIN
  BUYER
  SALES_REP
  PURCHASING
  AP
  RECEIVING
  SHIPPING
  OTHER
}

enum LocationType {
  OWN_PLANT
  OWN_WAREHOUSE
  OFFICE
  CUSTOMER
  SUPPLIER
  OTHER
}

enum ProductType {
  CORRUGATED_BOX
  PACKAGING_SUPPLY
  RESALE
  LABOR_SERVICE
  OTHER
}

enum BoxStyle {
  RSC
  HSC
  FOL
  TELESCOPE
  DIE_CUT
  BLISS
  TRAY
  OTHER
}

enum Flute {
  A
  B
  C
  E
  F
  BC
  EB
  OTHER
}

enum WallType {
  SINGLE
  DOUBLE
  TRIPLE
}

enum PrintType {
  NONE
  ONE_COLOR
  TWO_COLOR
  THREE_COLOR
  FOUR_COLOR
}

enum CoatingType {
  NONE
  WAX
  CLAY
  UV
  VARNISH
}

enum GrainDirection {
  LONG_GRAIN
  SHORT_GRAIN
}

enum JointType {
  GLUED
  STAPLED
  TAPED
  NONE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OrderStatus {
  OPEN
  IN_PRODUCTION
  PARTIALLY_SHIPPED
  SHIPPED
  INVOICED
  CANCELLED
}

enum JobStatus {
  QUEUED
  IN_PROGRESS
  COMPLETE
  ON_HOLD
  CANCELLED
}

enum JobReadiness {
  WAITING_SHEETS
  WAITING_TOOLING
  WAITING_BOTH
  READY
  SCHEDULED
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  VOIDED
}

enum ShipmentStage {
  DRAFT
  WAREHOUSE_ENTERED
  CONFIRMED
  SHIPPED
  DELIVERED
}

enum VarianceReason {
  RECOUNT
  DAMAGE
  CUSTOMER_REQUEST
  TOLERANCE_APPLIED
  HOLD_FOR_NEXT_SHIPMENT
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOIDED
}

enum QbSyncStatus {
  NOT_SYNCED
  SYNCED
  ERROR
}

enum PoStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum TransactionType {
  RECEIPT
  CONSUMPTION
  ADJUSTMENT
  TRANSFER
  ISSUED_TO_JOB
  RETURNED_FROM_JOB
  CONVERTED_TO_FG
  WASTE
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum ToolType {
  DIE
  PLATE
  OTHER
}

enum ToolCondition {
  NEW
  GOOD
  WORN
  RETIRED
}

// ─────────────────────────────────────────────────────────────────────────────
// LOOKUP TABLES (admin-managed)
// ─────────────────────────────────────────────────────────────────────────────

model PaymentTerm {
  id              Int      @id @default(autoincrement())
  termCode        String   @unique
  termName        String
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountDays    Int      @default(0)
  netDays         Int
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  customers Customer[]
  suppliers Supplier[]
}

model MaterialType {
  id        Int      @id @default(autoincrement())
  typeKey   String   @unique
  typeName  String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  materials Material[]
}

model WorkCenterType {
  id        Int      @id @default(autoincrement())
  typeKey   String   @unique
  typeName  String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  workCenters WorkCenter[]
  equipment   Equipment[]
  operations  Operation[]
}

// ─────────────────────────────────────────────────────────────────────────────
// USER MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CSR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotesCreated          Quote[]                @relation("QuoteCreatedBy")
  ordersCreated          SalesOrder[]           @relation("OrderCreatedBy")
  purchaseOrdersCreated  PurchaseOrder[]        @relation("POCreatedBy")
  materialTransactions   MaterialTransaction[]  @relation("TransactionCreatedBy")
  customersAsRep         Customer[]             @relation("CustomerSalesRep")
  confirmedShipments     Shipment[]             @relation("ShipmentConfirmedBy")
  productionConsumptions ProductionConsumption[]
  inventoryTransfers     InventoryTransfer[]
}

// ─────────────────────────────────────────────────────────────────────────────
// MASTER DATA
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  locationType LocationType @default(OWN_PLANT)
  isRegistered Boolean      @default(false)
  isDefault    Boolean      @default(false)
  street       String?
  city         String?
  state        String?
  zip          String?
  country      String?      @default("US")
  phone        String?
  email        String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  inventory              MaterialInventory[]
  receipts               MaterialReceipt[]
  transactions           MaterialTransaction[]
  jobs                   ProductionJob[]
  shipments              Shipment[]
  tooling                Tooling[]
  finishedGoodsInventory FinishedGoodsInventory[]
  productionConsumptions ProductionConsumption[]
  transfersFrom          InventoryTransfer[]      @relation("TransferFrom")
  transfersTo            InventoryTransfer[]      @relation("TransferTo")
  equipment              Equipment[]
  workCenters            WorkCenter[]
}

model Customer {
  id                       Int      @id @default(autoincrement())
  code                     String   @unique
  name                     String
  accountNumber            String?
  taxId                    String?
  resaleCertificateNumber  String?
  street                   String?
  city                     String?
  state                    String?
  zip                      String?
  country                  String?  @default("US")
  billingStreet            String?
  billingCity              String?
  billingState             String?
  billingZip               String?
  billingCountry           String?  @default("US")
  paymentTermId            Int?
  creditLimit              Decimal? @db.Decimal(12, 2)
  creditHold               Boolean  @default(false)
  taxExempt                Boolean  @default(false)
  taxExemptId              String?
  defaultSalesRepId        Int?
  notes                    String?
  defaultOverTolerance     Decimal  @default(10.0) @db.Decimal(6, 2)
  defaultUnderTolerance    Decimal  @default(10.0) @db.Decimal(6, 2)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  paymentTerm    PaymentTerm?      @relation(fields: [paymentTermId], references: [id])
  defaultSalesRep User?            @relation("CustomerSalesRep", fields: [defaultSalesRepId], references: [id])
  contacts       CustomerContact[]
  shipToAddresses ShipToAddress[]
  quotes         Quote[]
  orders         SalesOrder[]
  invoices       Invoice[]
  tooling        Tooling[]

  @@index([defaultSalesRepId])
  @@index([paymentTermId])
}

model CustomerContact {
  id                   Int         @id @default(autoincrement())
  customerId           Int
  name                 String
  title                String?
  email                String?
  phone                String?
  contactType          ContactType
  isPrimary            Boolean     @default(false)
  invoiceDistribution  Boolean     @default(false)
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

model ShipToAddress {
  id                   Int      @id @default(autoincrement())
  customerId           Int
  locationName         String
  street               String?
  city                 String?
  state                String?
  zip                  String?
  country              String?  @default("US")
  contactName          String?
  contactPhone         String?
  contactEmail         String?
  isDefault            Boolean  @default(false)
  deliveryInstructions String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

model WorkCenter {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  workCenterTypeId Int?
  description      String?
  locationId       Int?
  equipmentId      Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  workCenterType WorkCenterType? @relation(fields: [workCenterTypeId], references: [id])
  location       Location?       @relation(fields: [locationId], references: [id])
  equipment      Equipment?      @relation(fields: [equipmentId], references: [id])
  jobs           ProductionJob[]

  @@index([workCenterTypeId])
  @@index([locationId])
}

model Supplier {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  name            String
  accountNumber   String?
  taxId           String?
  is1099Eligible  Boolean  @default(false)
  name1099        String?
  street          String?
  city            String?
  state           String?
  zip             String?
  country         String?  @default("US")
  paymentTermId   Int?
  creditLimit     Decimal? @db.Decimal(12, 2)
  w9OnFile        Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paymentTerm    PaymentTerm?      @relation(fields: [paymentTermId], references: [id])
  contacts       SupplierContact[]
  purchaseOrders PurchaseOrder[]
  partsForEquipment Equipment[]
}

model SupplierContact {
  id                  Int         @id @default(autoincrement())
  supplierId          Int
  name                String
  title               String?
  email               String?
  phone               String?
  contactType         ContactType
  isPrimary           Boolean     @default(false)
  invoiceDistribution Boolean     @default(false)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT & OPERATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Equipment {
  id                  Int      @id @default(autoincrement())
  name                String
  equipmentTypeId     Int
  locationId          Int
  manufacturer        String?
  modelNumber         String?
  serialNumber        String?
  yearOfManufacture   Int?
  maxSheetWidth       Decimal? @db.Decimal(8, 3)
  maxSheetLength      Decimal? @db.Decimal(8, 3)
  minSheetWidth       Decimal? @db.Decimal(8, 3)
  minSheetLength      Decimal? @db.Decimal(8, 3)
  maxSpeed            Decimal? @db.Decimal(10, 2)
  purchaseDate        DateTime?
  purchasePrice       Decimal? @db.Decimal(12, 2)
  warrantyExpiry      DateTime?
  lastServiceDate     DateTime?
  nextServiceDue      DateTime?
  assetTagId          String?
  partsSupplierId     Int?
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  equipmentType  WorkCenterType       @relation(fields: [equipmentTypeId], references: [id])
  location       Location             @relation(fields: [locationId], references: [id])
  partsSupplier  Supplier?            @relation(fields: [partsSupplierId], references: [id])
  capabilities   EquipmentCapability[]
  workCenters    WorkCenter[]

  @@index([equipmentTypeId])
  @@index([locationId])
  @@index([partsSupplierId])
}

model Operation {
  id                     Int      @id @default(autoincrement())
  operationKey           String   @unique
  operationName          String
  defaultEquipmentTypeId Int?
  isActive               Boolean  @default(true)
  sortOrder              Int      @default(0)

  defaultEquipmentType WorkCenterType?      @relation(fields: [defaultEquipmentTypeId], references: [id])
  capabilities         EquipmentCapability[]
}

model EquipmentCapability {
  id          Int      @id @default(autoincrement())
  equipmentId Int
  operationId Int
  maxSpeed    Decimal? @db.Decimal(10, 2)
  notes       String?

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  operation Operation @relation(fields: [operationId], references: [id])

  @@unique([equipmentId, operationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MATERIALS & INVENTORY
// ─────────────────────────────────────────────────────────────────────────────

model Material {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  name           String
  materialTypeId Int?
  unitOfMeasure  String
  defaultCost    Decimal? @db.Decimal(12, 4)
  reorderPoint   Decimal? @db.Decimal(12, 4)
  reorderQty     Decimal? @db.Decimal(12, 4)
  leadTimeDays   Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  materialType           MaterialType?          @relation(fields: [materialTypeId], references: [id])
  inventory              MaterialInventory[]
  receipts               MaterialReceipt[]
  transactions           MaterialTransaction[]
  bomLines               BOMLine[]
  quoteItemBomLines      QuoteItemBOMLine[]
  blankSpecs             BlankSpec[]
  purchaseOrderItems     PurchaseOrderItem[]
  variants               MaterialVariant[]
  productionConsumptions ProductionConsumption[]
  inventoryTransfers     InventoryTransfer[]

  @@index([materialTypeId])
}

model MaterialVariant {
  id            Int      @id @default(autoincrement())
  materialId    Int
  variantCode   String   @unique
  description   String?
  rollWidth     Decimal? @db.Decimal(8, 3)
  sheetLength   Decimal? @db.Decimal(8, 3)
  sheetWidth    Decimal? @db.Decimal(8, 3)
  unitOfMeasure String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  material               Material               @relation(fields: [materialId], references: [id])
  blankSpecs             BlankSpec[]
  productionConsumptions ProductionConsumption[]
  inventoryTransfers     InventoryTransfer[]

  @@index([materialId])
}

model MaterialInventory {
  id         Int      @id @default(autoincrement())
  materialId Int
  locationId Int
  quantity   Decimal  @default(0) @db.Decimal(14, 4)
  avgCost    Decimal  @default(0) @db.Decimal(12, 4)
  updatedAt  DateTime @updatedAt

  material Material @relation(fields: [materialId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([materialId, locationId])
  @@index([locationId])
}

model MaterialReceipt {
  id                  Int      @id @default(autoincrement())
  materialId          Int
  locationId          Int
  purchaseOrderItemId Int?
  quantity            Decimal  @db.Decimal(14, 4)
  unitCost            Decimal  @db.Decimal(12, 4)
  vendorName          String?
  receivedAt          DateTime @default(now())
  notes               String?
  createdAt           DateTime @default(now())

  material          Material           @relation(fields: [materialId], references: [id])
  location          Location           @relation(fields: [locationId], references: [id])
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])

  @@index([materialId])
  @@index([purchaseOrderItemId])
}

model MaterialTransaction {
  id            Int             @id @default(autoincrement())
  materialId    Int
  locationId    Int
  type          TransactionType
  quantity      Decimal         @db.Decimal(14, 4)
  referenceType String?
  referenceId   Int?
  notes         String?
  createdById   Int
  createdAt     DateTime        @default(now())

  material  Material @relation(fields: [materialId], references: [id])
  location  Location @relation(fields: [locationId], references: [id])
  createdBy User     @relation("TransactionCreatedBy", fields: [createdById], references: [id])

  @@index([materialId, locationId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASING
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseOrder {
  id                   Int      @id @default(autoincrement())
  poNumber             String   @unique
  supplierId           Int
  createdById          Int
  status               PoStatus @default(DRAFT)
  expectedDeliveryDate DateTime?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  supplier  Supplier           @relation(fields: [supplierId], references: [id])
  createdBy User               @relation("POCreatedBy", fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id               Int     @id @default(autoincrement())
  poId             Int
  materialId       Int
  lineNumber       Int
  quantityOrdered  Decimal @db.Decimal(14, 4)
  quantityReceived Decimal @default(0) @db.Decimal(14, 4)
  unitCost         Decimal @db.Decimal(12, 4)
  notes            String?

  purchaseOrder PurchaseOrder     @relation(fields: [poId], references: [id], onDelete: Cascade)
  material      Material          @relation(fields: [materialId], references: [id])
  receipts      MaterialReceipt[]

  @@unique([poId, lineNumber])
  @@index([poId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────────────────────

model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String
  parentId    Int?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
}

model Product {
  id          Int         @id @default(autoincrement())
  sku         String      @unique
  name        String
  description String?
  productType ProductType
  categoryId  Int?
  isCustom    Boolean     @default(false)
  listPrice   Decimal?    @db.Decimal(12, 4)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  category               ProductCategory?       @relation(fields: [categoryId], references: [id])
  boxSpec                BoxSpec?               @relation("ProductBoxSpec")
  blankSpec              BlankSpec?             @relation("ProductBlankSpec")
  bomLines               BOMLine[]
  quoteItems             QuoteItem[]
  orderItems             SalesOrderItem[]
  variants               ProductVariant[]
  specs                  ProductSpec[]
  finishedGoodsInventory FinishedGoodsInventory[]
  inventoryTransfers     InventoryTransfer[]

  @@index([productType])
  @@index([categoryId])
}

model BoxSpec {
  id                Int      @id @default(autoincrement())
  productId         Int?     @unique
  quoteItemId       Int?     @unique
  lengthInches      Decimal  @db.Decimal(8, 3)
  widthInches       Decimal  @db.Decimal(8, 3)
  heightInches      Decimal  @db.Decimal(8, 3)
  outsideDimensions Boolean  @default(false)
  style             BoxStyle @default(RSC)
  hasDieCut         Boolean  @default(false)
  hasPerforations   Boolean  @default(false)
  notes             String?

  product   Product?   @relation("ProductBoxSpec",   fields: [productId],   references: [id])
  quoteItem QuoteItem? @relation("QuoteItemBoxSpec", fields: [quoteItemId], references: [id])
}

model BlankSpec {
  id          Int    @id @default(autoincrement())
  productId   Int?   @unique
  quoteItemId Int?   @unique
  materialId  Int

  outsPerSheet      Int      @default(1)
  sheetsPerBox      Decimal  @default(1.0) @db.Decimal(8, 4)
  sheetLengthInches Decimal? @db.Decimal(8, 3)
  sheetWidthInches  Decimal? @db.Decimal(8, 3)
  layoutNotes       String?
  rollWidthRequired Decimal? @db.Decimal(8, 3)

  requiredDieId     Int?
  requiredPlateIds  String?
  materialVariantId Int?

  blankLengthInches Decimal        @db.Decimal(8, 3)
  blankWidthInches  Decimal        @db.Decimal(8, 3)
  grainDirection    GrainDirection

  boardGrade String
  flute      Flute
  wallType   WallType

  scoreCount     Int
  scorePositions String

  slotDepth Decimal? @db.Decimal(8, 3)
  slotWidth Decimal? @db.Decimal(8, 3)

  specialCuts String?
  trimAmount  Decimal? @db.Decimal(8, 3)
  jointType   JointType

  printType    PrintType   @default(NONE)
  printColors  Int         @default(0)
  inkTypes     String?
  plateNumbers String?
  coating      CoatingType @default(NONE)

  bundleCount     Int?
  tieHigh         Int?
  tierWide        Int?
  palletsPerOrder Int?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product         Product?         @relation("ProductBlankSpec",   fields: [productId],        references: [id])
  quoteItem       QuoteItem?       @relation("QuoteItemBlankSpec", fields: [quoteItemId],       references: [id])
  material        Material         @relation(fields: [materialId],        references: [id])
  requiredDie     Tooling?         @relation("BlankSpecDie",              fields: [requiredDieId],    references: [id])
  materialVariant MaterialVariant? @relation(fields: [materialVariantId], references: [id])
}

model BOMLine {
  id            Int     @id @default(autoincrement())
  productId     Int
  materialId    Int
  quantityPer   Decimal @db.Decimal(14, 6)
  unitOfMeasure String

  product  Product  @relation(fields: [productId],  references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@unique([productId, materialId])
}

model Tooling {
  id          Int           @id @default(autoincrement())
  toolNumber  String        @unique
  type        ToolType
  description String?
  customerId  Int?
  condition   ToolCondition
  locationId  Int
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customer   Customer?   @relation(fields: [customerId], references: [id])
  location   Location    @relation(fields: [locationId], references: [id])
  blankSpecs BlankSpec[] @relation("BlankSpecDie")

  @@index([customerId])
  @@index([type])
}

model ProductVariant {
  id                 Int      @id @default(autoincrement())
  productId          Int
  sku                String   @unique
  variantDescription String?
  width              Decimal? @db.Decimal(8, 3)
  length             Decimal? @db.Decimal(8, 3)
  thickness          Decimal? @db.Decimal(8, 3)
  bundleQty          Int?
  caseQty            Int?
  listPrice          Decimal? @db.Decimal(12, 4)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product                Product                @relation(fields: [productId], references: [id])
  specs                  ProductSpec[]
  quoteItems             QuoteItem[]
  orderItems             SalesOrderItem[]
  shipmentItems          ShipmentItem[]
  finishedGoodsInventory FinishedGoodsInventory[]

  @@index([productId])
}

model ProductSpec {
  id        Int    @id @default(autoincrement())
  productId Int
  variantId Int?
  specKey   String
  specValue String
  specUnit  String?
  sortOrder Int?

  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
}

model FinishedGoodsInventory {
  id         Int      @id @default(autoincrement())
  productId  Int
  variantId  Int?
  locationId Int
  quantity   Decimal  @default(0) @db.Decimal(14, 4)
  avgCost    Decimal? @db.Decimal(12, 4)
  updatedAt  DateTime @updatedAt

  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])
  location Location        @relation(fields: [locationId], references: [id])

  @@index([productId])
  @@index([locationId])
}

model InventoryTransfer {
  id              Int            @id @default(autoincrement())
  materialId      Int?
  productId       Int?
  variantId       Int?
  fromLocationId  Int
  toLocationId    Int
  quantity        Decimal        @db.Decimal(14, 4)
  transferredById Int
  transferredAt   DateTime
  notes           String?
  status          TransferStatus @default(PENDING)

  material        Material?        @relation(fields: [materialId],       references: [id])
  product         Product?         @relation(fields: [productId],        references: [id])
  materialVariant MaterialVariant? @relation(fields: [variantId],        references: [id])
  fromLocation    Location         @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation      Location         @relation("TransferTo",   fields: [toLocationId],   references: [id])
  transferredBy   User             @relation(fields: [transferredById],  references: [id])

  @@index([materialId])
  @@index([productId])
  @@index([fromLocationId])
  @@index([toLocationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTING
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id          Int         @id @default(autoincrement())
  quoteNumber String      @unique
  customerId  Int
  createdById Int
  status      QuoteStatus @default(DRAFT)
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer  Customer    @relation(fields: [customerId],  references: [id])
  createdBy User        @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  items     QuoteItem[]
  order     SalesOrder?

  @@index([customerId])
  @@index([status])
}

model QuoteItem {
  id          Int     @id @default(autoincrement())
  quoteId     Int
  productId   Int?
  variantId   Int?
  lineNumber  Int
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 4)
  notes       String?

  quote      Quote              @relation(fields: [quoteId],    references: [id], onDelete: Cascade)
  product    Product?           @relation(fields: [productId],  references: [id])
  variant    ProductVariant?    @relation(fields: [variantId],  references: [id])
  boxSpec    BoxSpec?           @relation("QuoteItemBoxSpec")
  blankSpec  BlankSpec?         @relation("QuoteItemBlankSpec")
  bomLines   QuoteItemBOMLine[]
  orderItems SalesOrderItem[]

  @@unique([quoteId, lineNumber])
  @@index([quoteId])
}

model QuoteItemBOMLine {
  id          Int     @id @default(autoincrement())
  quoteItemId Int
  materialId  Int
  quantityPer Decimal @db.Decimal(14, 6)
  unitCost    Decimal @db.Decimal(12, 4)

  quoteItem QuoteItem @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)
  material  Material  @relation(fields: [materialId],  references: [id])

  @@unique([quoteItemId, materialId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SALES ORDERS
// ─────────────────────────────────────────────────────────────────────────────

model SalesOrder {
  id                 Int         @id @default(autoincrement())
  orderNumber        String      @unique
  quoteId            Int?        @unique
  customerId         Int
  createdById        Int
  status             OrderStatus @default(OPEN)
  orderDate          DateTime    @default(now())
  requestedShipDate  DateTime?
  customerPONumber   String?
  customerPODate     DateTime?
  customerPODocument String?
  overTolerance      Decimal?    @db.Decimal(6, 2)
  underTolerance     Decimal?    @db.Decimal(6, 2)
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  quote     Quote?          @relation(fields: [quoteId],     references: [id])
  customer  Customer        @relation(fields: [customerId],  references: [id])
  createdBy User            @relation("OrderCreatedBy", fields: [createdById], references: [id])
  items     SalesOrderItem[]
  shipments Shipment[]
  invoices  Invoice[]

  @@index([customerId])
  @@index([status])
}

model SalesOrderItem {
  id                Int      @id @default(autoincrement())
  orderId           Int
  quoteItemId       Int?
  productId         Int?
  variantId         Int?
  lineNumber        Int
  description       String
  quantity          Int
  unitPrice         Decimal  @db.Decimal(12, 4)
  qtyShipped        Int      @default(0)
  toleranceOverride Boolean  @default(false)
  qtyTolerance      Decimal? @db.Decimal(6, 2)

  order         SalesOrder      @relation(fields: [orderId],     references: [id], onDelete: Cascade)
  quoteItem     QuoteItem?      @relation(fields: [quoteItemId], references: [id])
  product       Product?        @relation(fields: [productId],   references: [id])
  variant       ProductVariant? @relation(fields: [variantId],   references: [id])
  jobs          ProductionJob[]
  shipmentItems ShipmentItem[]

  @@unique([orderId, lineNumber])
  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTION
// ─────────────────────────────────────────────────────────────────────────────

model ProductionJob {
  id                    Int          @id @default(autoincrement())
  jobNumber             String       @unique
  orderItemId           Int
  workCenterId          Int
  locationId            Int
  sequence              Int
  status                JobStatus    @default(QUEUED)
  jobReadiness          JobReadiness @default(READY)
  sheetsConfirmed       Boolean      @default(false)
  toolingConfirmed      Boolean      @default(false)
  scheduledDate         DateTime?
  completedDate         DateTime?
  quantityOrdered       Int
  quantityComplete      Int          @default(0)
  quantityGoodOutput    Int          @default(0)
  quantityWaste         Int          @default(0)
  wasteQty              Int          @default(0)
  rawMaterialConsumed   Decimal      @default(0) @db.Decimal(14, 4)
  finishedGoodsProduced Int          @default(0)
  estimatedSetupMinutes Int?
  actualSetupMinutes    Int?
  estimatedRunMinutes   Int?
  actualRunMinutes      Int?
  plateNumber           String?
  dieNumber             String?
  notes                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  orderItem    SalesOrderItem        @relation(fields: [orderItemId],  references: [id])
  workCenter   WorkCenter            @relation(fields: [workCenterId], references: [id])
  location     Location              @relation(fields: [locationId],   references: [id])
  consumptions ProductionConsumption[]

  @@index([status])
  @@index([workCenterId])
  @@index([scheduledDate])
}

model ProductionConsumption {
  id                   Int      @id @default(autoincrement())
  productionJobId      Int
  materialId           Int
  variantId            Int?
  locationId           Int
  quantityIssued       Decimal  @db.Decimal(14, 4)
  quantityActuallyUsed Decimal  @db.Decimal(14, 4)
  quantityReturned     Decimal  @default(0) @db.Decimal(14, 4)
  wasteQuantity        Decimal  @default(0) @db.Decimal(14, 4)
  consumedAt           DateTime
  consumedById         Int

  productionJob   ProductionJob    @relation(fields: [productionJobId], references: [id])
  material        Material         @relation(fields: [materialId],      references: [id])
  materialVariant MaterialVariant? @relation(fields: [variantId],       references: [id])
  location        Location         @relation(fields: [locationId],      references: [id])
  consumedBy      User             @relation(fields: [consumedById],    references: [id])

  @@index([productionJobId])
  @@index([materialId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SHIPPING
// ─────────────────────────────────────────────────────────────────────────────

model Shipment {
  id                  Int            @id @default(autoincrement())
  shipmentNumber      String         @unique
  orderId             Int
  locationId          Int
  status              ShipmentStatus @default(PENDING)
  shipmentStage       ShipmentStage  @default(DRAFT)
  carrier             String?
  trackingNumber      String?
  bolNumber           String?
  totalWeight         Decimal?       @db.Decimal(10, 2)
  palletCount         Int?
  systemSuggestedQty  Decimal?       @db.Decimal(14, 4)
  warehouseEnteredQty Decimal?       @db.Decimal(14, 4)
  confirmedQty        Decimal?       @db.Decimal(14, 4)
  confirmedById       Int?
  confirmedAt         DateTime?
  varianceQty         Decimal?       @db.Decimal(14, 4)
  varianceReason      VarianceReason?
  shippedAt           DateTime?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  order       SalesOrder    @relation(fields: [orderId],      references: [id])
  location    Location      @relation(fields: [locationId],   references: [id])
  confirmedBy User?         @relation("ShipmentConfirmedBy", fields: [confirmedById], references: [id])
  items       ShipmentItem[]
  invoices    Invoice[]

  @@index([orderId])
  @@index([status])
}

model ShipmentItem {
  id                  Int     @id @default(autoincrement())
  shipmentId          Int
  orderItemId         Int
  variantId           Int?
  quantity            Int
  systemSuggestedQty  Decimal? @db.Decimal(14, 4)
  warehouseEnteredQty Decimal? @db.Decimal(14, 4)
  confirmedQty        Decimal? @db.Decimal(14, 4)
  varianceNotes       String?

  shipment  Shipment        @relation(fields: [shipmentId],  references: [id], onDelete: Cascade)
  orderItem SalesOrderItem  @relation(fields: [orderItemId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId],   references: [id])

  @@unique([shipmentId, orderItemId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICING
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  orderId       Int
  shipmentId    Int?
  customerId    Int
  status        InvoiceStatus @default(DRAFT)
  invoiceDate   DateTime
  dueDate       DateTime
  totalAmount   Decimal       @db.Decimal(12, 2)
  qbSyncStatus  QbSyncStatus  @default(NOT_SYNCED)
  qbSyncedAt    DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order    SalesOrder @relation(fields: [orderId],    references: [id])
  shipment Shipment?  @relation(fields: [shipmentId], references: [id])
  customer Customer   @relation(fields: [customerId], references: [id])

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([qbSyncStatus])
}
