// BoxERP — Prisma Schema v7
// Session 4 Review v2: Architecture Overhaul
//   - Party model (Party, PartyRole, PartyContact) — unified contacts
//   - Unified Location (partyId, replaces ShipToAddress)
//   - Resource model (replaces WorkCenter + Equipment)
//   - Product → MasterSpec rename; ProductModule + ModuleSpecField
//   - CustomerItem, VariantSpec, InventoryCommitment

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CSR
}

enum PartyRoleType {
  CUSTOMER
  SUPPLIER
  CARRIER
  PROSPECT
  OTHER
}

enum ContactType {
  MAIN
  BUYER
  SALES_REP
  PURCHASING
  AP
  RECEIVING
  SHIPPING
  OTHER
}

enum LocationType {
  OWN_PLANT
  OWN_WAREHOUSE
  OFFICE
  CUSTOMER
  SUPPLIER
  OTHER
}

enum BoxStyle {
  RSC
  HSC
  FOL
  TELESCOPE
  DIE_CUT
  BLISS
  TRAY
  OTHER
}

enum Flute {
  A
  B
  C
  E
  F
  BC
  EB
  OTHER
}

enum WallType {
  SINGLE
  DOUBLE
  TRIPLE
}

enum PrintType {
  NONE
  ONE_COLOR
  TWO_COLOR
  THREE_COLOR
  FOUR_COLOR
}

enum CoatingType {
  NONE
  WAX
  CLAY
  UV
  VARNISH
}

enum GrainDirection {
  LONG_GRAIN
  SHORT_GRAIN
}

enum JointType {
  GLUED
  STAPLED
  TAPED
  NONE
}

enum FulfillmentPath {
  MANUFACTURE
  FULFILL_FROM_STOCK
  PURCHASE_RESELL
  DROP_SHIP
  CONVERT
  SERVICE
}

enum CommitmentStatus {
  PENDING
  COMMITTED
  RELEASED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OrderStatus {
  OPEN
  IN_PRODUCTION
  PARTIALLY_SHIPPED
  SHIPPED
  INVOICED
  CANCELLED
}

enum JobStatus {
  QUEUED
  IN_PROGRESS
  COMPLETE
  ON_HOLD
  CANCELLED
}

enum JobReadiness {
  WAITING_SHEETS
  WAITING_TOOLING
  WAITING_BOTH
  READY
  SCHEDULED
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  VOIDED
}

enum ShipmentStage {
  DRAFT
  WAREHOUSE_ENTERED
  CONFIRMED
  SHIPPED
  DELIVERED
}

enum VarianceReason {
  RECOUNT
  DAMAGE
  CUSTOMER_REQUEST
  TOLERANCE_APPLIED
  HOLD_FOR_NEXT_SHIPMENT
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOIDED
}

enum QbSyncStatus {
  NOT_SYNCED
  SYNCED
  ERROR
}

enum PoStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum TransactionType {
  RECEIPT
  CONSUMPTION
  ADJUSTMENT
  TRANSFER
  ISSUED_TO_JOB
  RETURNED_FROM_JOB
  CONVERTED_TO_FG
  WASTE
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum ToolType {
  DIE
  PLATE
  OTHER
}

enum ToolCondition {
  NEW
  GOOD
  WORN
  RETIRED
}

// ─────────────────────────────────────────────────────────────────────────────
// LOOKUP / ADMIN TABLES
// ─────────────────────────────────────────────────────────────────────────────

model PaymentTerm {
  id              Int      @id @default(autoincrement())
  termCode        String   @unique
  termName        String
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountDays    Int      @default(0)
  netDays         Int
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  customers Customer[]
  suppliers Supplier[]
}

model MaterialType {
  id        Int      @id @default(autoincrement())
  typeKey   String   @unique
  typeName  String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  materials Material[]
}

model ResourceType {
  id        Int      @id @default(autoincrement())
  typeKey   String   @unique
  typeName  String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  resources             Resource[]
  operationRequirements OperationRequirement[]
}

model ProductModule {
  id         Int      @id @default(autoincrement())
  moduleKey  String   @unique
  moduleName String
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)

  specFields ModuleSpecField[]
  categories ProductCategory[]
}

model BoardGrade {
  id              Int      @id @default(autoincrement())
  gradeCode       String   @unique
  gradeName       String
  wallType        String   // SW, DW, TW
  nominalCaliper  Decimal  @db.Decimal(6, 3)
  description     String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  variants ProductVariant[]
}

model ModuleSpecField {
  id            Int      @id @default(autoincrement())
  moduleId      Int
  fieldKey      String
  fieldLabel    String
  fieldType     String   // TEXT, NUMBER, BOOLEAN, SELECT
  selectOptions String?  // JSON array for SELECT type
  isRequired    Boolean  @default(false)
  sortOrder     Int      @default(0)

  module       ProductModule @relation(fields: [moduleId], references: [id])
  variantSpecs VariantSpec[]

  @@unique([moduleId, fieldKey])
}

// ─────────────────────────────────────────────────────────────────────────────
// PARTY MODEL — universal entity
// ─────────────────────────────────────────────────────────────────────────────

model Party {
  id        Int      @id @default(autoincrement())
  partyCode String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles     PartyRole[]
  contacts  PartyContact[]
  locations Location[]
  customers Customer[]
  suppliers Supplier[]
}

model PartyRole {
  id        Int           @id @default(autoincrement())
  partyId   Int
  roleType  PartyRoleType
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  party Party @relation(fields: [partyId], references: [id])

  @@unique([partyId, roleType])
  @@index([partyId])
}

model PartyContact {
  id                  Int         @id @default(autoincrement())
  partyId             Int
  name                String?
  title               String?
  email               String?
  phone               String?
  contactType         ContactType
  isPrimary           Boolean     @default(false)
  invoiceDistribution Boolean     @default(false)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  party Party @relation(fields: [partyId], references: [id])

  @@index([partyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// USER MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CSR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotesCreated          Quote[]                @relation("QuoteCreatedBy")
  ordersCreated          SalesOrder[]           @relation("OrderCreatedBy")
  purchaseOrdersCreated  PurchaseOrder[]        @relation("POCreatedBy")
  materialTransactions   MaterialTransaction[]  @relation("TransactionCreatedBy")
  customersAsRep         Customer[]             @relation("CustomerSalesRep")
  confirmedShipments     Shipment[]             @relation("ShipmentConfirmedBy")
  productionConsumptions ProductionConsumption[]
  inventoryTransfers     InventoryTransfer[]
}

// ─────────────────────────────────────────────────────────────────────────────
// MASTER DATA
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id                   Int          @id @default(autoincrement())
  name                 String       @unique
  locationType         LocationType @default(OWN_PLANT)
  partyId              Int?
  isRegistered         Boolean      @default(false)
  isDefault            Boolean      @default(false)
  street               String?
  city                 String?
  state                String?
  zip                  String?
  country              String?      @default("US")
  phone                String?
  email                String?
  contactName          String?
  contactPhone         String?
  contactEmail         String?
  deliveryInstructions String?
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())

  party                  Party?                   @relation(fields: [partyId], references: [id])
  inventory              MaterialInventory[]
  receipts               MaterialReceipt[]
  transactions           MaterialTransaction[]
  jobs                   ProductionJob[]
  shipments              Shipment[]
  tooling                Tooling[]
  finishedGoodsInventory FinishedGoodsInventory[]
  productionConsumptions ProductionConsumption[]
  transfersFrom          InventoryTransfer[]      @relation("TransferFrom")
  transfersTo            InventoryTransfer[]      @relation("TransferTo")
  resources              Resource[]
  inventoryCommitments   InventoryCommitment[]

  @@index([partyId])
}

model Customer {
  id                       Int      @id @default(autoincrement())
  code                     String   @unique
  name                     String
  partyId                  Int?
  accountNumber            String?
  taxId                    String?
  resaleCertificateNumber  String?
  street                   String?
  city                     String?
  state                    String?
  zip                      String?
  country                  String?  @default("US")
  billingStreet            String?
  billingCity              String?
  billingState             String?
  billingZip               String?
  billingCountry           String?  @default("US")
  paymentTermId            Int?
  creditLimit              Decimal? @db.Decimal(12, 2)
  creditHold               Boolean  @default(false)
  taxExempt                Boolean  @default(false)
  taxExemptId              String?
  defaultSalesRepId        Int?
  notes                    String?
  defaultOverTolerance     Decimal  @default(10.0) @db.Decimal(6, 2)
  defaultUnderTolerance    Decimal  @default(10.0) @db.Decimal(6, 2)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  party           Party?        @relation(fields: [partyId], references: [id])
  paymentTerm     PaymentTerm?  @relation(fields: [paymentTermId], references: [id])
  defaultSalesRep User?         @relation("CustomerSalesRep", fields: [defaultSalesRepId], references: [id])
  quotes          Quote[]
  orders          SalesOrder[]
  invoices        Invoice[]
  tooling         Tooling[]
  customerItems   CustomerItem[]

  @@index([partyId])
  @@index([defaultSalesRepId])
  @@index([paymentTermId])
}

model Supplier {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  name            String
  partyId         Int?
  accountNumber   String?
  taxId           String?
  is1099Eligible  Boolean  @default(false)
  name1099        String?
  street          String?
  city            String?
  state           String?
  zip             String?
  country         String?  @default("US")
  paymentTermId   Int?
  creditLimit     Decimal? @db.Decimal(12, 2)
  w9OnFile        Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  party          Party?           @relation(fields: [partyId], references: [id])
  paymentTerm    PaymentTerm?     @relation(fields: [paymentTermId], references: [id])
  purchaseOrders PurchaseOrder[]
  resources      Resource[]

  @@index([partyId])
}

// ─────────────────────────────────────────────────────────────────────────────
// RESOURCES & OPERATIONS (replaces WorkCenter + Equipment)
// ─────────────────────────────────────────────────────────────────────────────

model Resource {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  resourceTypeId    Int
  locationId        Int
  description       String?
  manufacturer      String?
  modelNumber       String?
  serialNumber      String?
  yearOfManufacture Int?
  maxSheetWidth     Decimal? @db.Decimal(8, 3)
  maxSheetLength    Decimal? @db.Decimal(8, 3)
  minSheetWidth     Decimal? @db.Decimal(8, 3)
  minSheetLength    Decimal? @db.Decimal(8, 3)
  maxSpeed          Decimal? @db.Decimal(10, 2)
  purchaseDate      DateTime?
  purchasePrice     Decimal? @db.Decimal(12, 2)
  warrantyExpiry    DateTime?
  lastServiceDate   DateTime?
  nextServiceDue    DateTime?
  assetTagId        String?
  partsSupplierId   Int?
  notes             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  resourceType  ResourceType         @relation(fields: [resourceTypeId], references: [id])
  location      Location             @relation(fields: [locationId], references: [id])
  partsSupplier Supplier?            @relation(fields: [partsSupplierId], references: [id])
  capabilities  ResourceCapability[]
  jobs          ProductionJob[]

  @@index([resourceTypeId])
  @@index([locationId])
  @@index([partsSupplierId])
}

model Operation {
  id            Int      @id @default(autoincrement())
  operationKey  String   @unique
  operationName String
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  capabilities          ResourceCapability[]
  operationRequirements OperationRequirement[]
}

model ResourceCapability {
  id          Int      @id @default(autoincrement())
  resourceId  Int
  operationId Int
  maxSpeed    Decimal? @db.Decimal(10, 2)
  notes       String?

  resource  Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  operation Operation @relation(fields: [operationId], references: [id])

  @@unique([resourceId, operationId])
}

model OperationRequirement {
  id             Int     @id @default(autoincrement())
  operationId    Int
  resourceTypeId Int
  isRequired     Boolean @default(true)
  notes          String?

  operation    Operation    @relation(fields: [operationId], references: [id])
  resourceType ResourceType @relation(fields: [resourceTypeId], references: [id])

  @@unique([operationId, resourceTypeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MATERIALS & INVENTORY
// ─────────────────────────────────────────────────────────────────────────────

model Material {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  name           String
  materialTypeId Int?
  unitOfMeasure  String
  defaultCost    Decimal? @db.Decimal(12, 4)
  reorderPoint   Decimal? @db.Decimal(12, 4)
  reorderQty     Decimal? @db.Decimal(12, 4)
  leadTimeDays   Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  materialType           MaterialType?          @relation(fields: [materialTypeId], references: [id])
  inventory              MaterialInventory[]
  receipts               MaterialReceipt[]
  transactions           MaterialTransaction[]
  bomLines               BOMLine[]
  quoteItemBomLines      QuoteItemBOMLine[]
  blankSpecs             BlankSpec[]
  purchaseOrderItems     PurchaseOrderItem[]
  variants               MaterialVariant[]
  productionConsumptions ProductionConsumption[]
  inventoryTransfers     InventoryTransfer[]

  @@index([materialTypeId])
}

model MaterialVariant {
  id            Int      @id @default(autoincrement())
  materialId    Int
  variantCode   String   @unique
  description   String?
  rollWidth     Decimal? @db.Decimal(8, 3)
  sheetLength   Decimal? @db.Decimal(8, 3)
  sheetWidth    Decimal? @db.Decimal(8, 3)
  unitOfMeasure String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  material               Material               @relation(fields: [materialId], references: [id])
  blankSpecs             BlankSpec[]
  productionConsumptions ProductionConsumption[]
  inventoryTransfers     InventoryTransfer[]

  @@index([materialId])
}

model MaterialInventory {
  id         Int      @id @default(autoincrement())
  materialId Int
  locationId Int
  quantity   Decimal  @default(0) @db.Decimal(14, 4)
  avgCost    Decimal  @default(0) @db.Decimal(12, 4)
  updatedAt  DateTime @updatedAt

  material Material @relation(fields: [materialId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([materialId, locationId])
  @@index([locationId])
}

model MaterialReceipt {
  id                  Int      @id @default(autoincrement())
  materialId          Int
  locationId          Int
  purchaseOrderItemId Int?
  quantity            Decimal  @db.Decimal(14, 4)
  unitCost            Decimal  @db.Decimal(12, 4)
  vendorName          String?
  receivedAt          DateTime @default(now())
  notes               String?
  createdAt           DateTime @default(now())

  material          Material           @relation(fields: [materialId], references: [id])
  location          Location           @relation(fields: [locationId], references: [id])
  purchaseOrderItem PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])

  @@index([materialId])
  @@index([purchaseOrderItemId])
}

model MaterialTransaction {
  id            Int             @id @default(autoincrement())
  materialId    Int
  locationId    Int
  type          TransactionType
  quantity      Decimal         @db.Decimal(14, 4)
  referenceType String?
  referenceId   Int?
  notes         String?
  createdById   Int
  createdAt     DateTime        @default(now())

  material  Material @relation(fields: [materialId], references: [id])
  location  Location @relation(fields: [locationId], references: [id])
  createdBy User     @relation("TransactionCreatedBy", fields: [createdById], references: [id])

  @@index([materialId, locationId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASING
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseOrder {
  id                   Int      @id @default(autoincrement())
  poNumber             String   @unique
  supplierId           Int
  createdById          Int
  status               PoStatus @default(DRAFT)
  expectedDeliveryDate DateTime?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  supplier  Supplier           @relation(fields: [supplierId], references: [id])
  createdBy User               @relation("POCreatedBy", fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id               Int     @id @default(autoincrement())
  poId             Int
  materialId       Int
  lineNumber       Int
  quantityOrdered  Decimal @db.Decimal(14, 4)
  quantityReceived Decimal @default(0) @db.Decimal(14, 4)
  unitCost         Decimal @db.Decimal(12, 4)
  notes            String?

  purchaseOrder PurchaseOrder     @relation(fields: [poId], references: [id], onDelete: Cascade)
  material      Material          @relation(fields: [materialId], references: [id])
  receipts      MaterialReceipt[]

  @@unique([poId, lineNumber])
  @@index([poId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS — now "MasterSpec" (physical manufacturable item)
// ─────────────────────────────────────────────────────────────────────────────

model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String
  parentId    Int?
  moduleId    Int?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryHierarchy")
  module      ProductModule?    @relation(fields: [moduleId], references: [id])
  masterSpecs MasterSpec[]

  @@index([parentId])
  @@index([moduleId])
}

model MasterSpec {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  description String?
  categoryId  Int?
  isCustom    Boolean  @default(false)
  listPrice   Decimal? @db.Decimal(12, 4)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category               ProductCategory?         @relation(fields: [categoryId], references: [id])
  boxSpec                BoxSpec?                 @relation("MasterSpecBoxSpec")
  variants               ProductVariant[]
  specs                  ProductSpec[]
  finishedGoodsInventory FinishedGoodsInventory[]
  inventoryTransfers     InventoryTransfer[]
  customerItems          CustomerItem[]
  tooling                Tooling[]
  inventoryCommitments   InventoryCommitment[]

  @@index([categoryId])
}

model CustomerItem {
  id              Int             @id @default(autoincrement())
  code            String          @unique
  name            String
  description     String?
  customerId      Int
  masterSpecId    Int?
  variantId       Int
  listPrice       Decimal?        @db.Decimal(12, 4)
  fulfillmentPath FulfillmentPath @default(MANUFACTURE)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  customer   Customer        @relation(fields: [customerId], references: [id])
  masterSpec MasterSpec?     @relation(fields: [masterSpecId], references: [id])
  variant    ProductVariant  @relation(fields: [variantId], references: [id])
  tooling    Tooling[]
  quoteItems QuoteItem[]
  orderItems SalesOrderItem[]

  @@index([customerId])
  @@index([masterSpecId])
  @@index([variantId])
}

model BoxSpec {
  id                Int      @id @default(autoincrement())
  masterSpecId      Int?     @unique
  quoteItemId       Int?     @unique
  lengthInches      Decimal  @db.Decimal(8, 3)
  widthInches       Decimal  @db.Decimal(8, 3)
  heightInches      Decimal  @db.Decimal(8, 3)
  outsideDimensions Boolean  @default(false)
  style             BoxStyle @default(RSC)
  hasDieCut         Boolean  @default(false)
  hasPerforations   Boolean  @default(false)
  notes             String?

  masterSpec MasterSpec? @relation("MasterSpecBoxSpec",   fields: [masterSpecId], references: [id])
  quoteItem  QuoteItem?  @relation("QuoteItemBoxSpec",    fields: [quoteItemId],  references: [id])
}

model BlankSpec {
  id          Int    @id @default(autoincrement())
  variantId   Int?   @unique
  quoteItemId Int?   @unique
  materialId   Int

  outsPerSheet      Int      @default(1)
  sheetsPerBox      Decimal  @default(1.0) @db.Decimal(8, 4)
  sheetLengthInches Decimal? @db.Decimal(8, 3)
  sheetWidthInches  Decimal? @db.Decimal(8, 3)
  layoutNotes       String?
  rollWidthRequired Decimal? @db.Decimal(8, 3)

  requiredDieId     Int?
  requiredPlateIds  String?
  materialVariantId Int?

  blankLengthInches Decimal        @db.Decimal(8, 3)
  blankWidthInches  Decimal        @db.Decimal(8, 3)
  grainDirection    GrainDirection

  boardGrade String
  flute      Flute
  wallType   WallType

  scoreCount     Int
  scorePositions String

  slotDepth Decimal? @db.Decimal(8, 3)
  slotWidth Decimal? @db.Decimal(8, 3)

  specialCuts String?
  trimAmount  Decimal? @db.Decimal(8, 3)
  jointType   JointType

  printType    PrintType   @default(NONE)
  printColors  Int         @default(0)
  inkTypes     String?
  plateNumbers String?
  coating      CoatingType @default(NONE)

  bundleCount     Int?
  tieHigh         Int?
  tierWide        Int?
  palletsPerOrder Int?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant         ProductVariant?  @relation("VariantBlankSpec",     fields: [variantId],      references: [id])
  quoteItem       QuoteItem?       @relation("QuoteItemBlankSpec",  fields: [quoteItemId],     references: [id])
  material        Material         @relation(fields: [materialId],        references: [id])
  requiredDie     Tooling?         @relation("BlankSpecDie",              fields: [requiredDieId],    references: [id])
  materialVariant MaterialVariant? @relation(fields: [materialVariantId], references: [id])
}

model BOMLine {
  id            Int     @id @default(autoincrement())
  variantId     Int
  materialId    Int
  quantityPer   Decimal @db.Decimal(14, 6)
  unitOfMeasure String

  variant  ProductVariant @relation(fields: [variantId], references: [id])
  material Material       @relation(fields: [materialId], references: [id])

  @@unique([variantId, materialId])
}

model Tooling {
  id             Int           @id @default(autoincrement())
  toolNumber     String        @unique
  type           ToolType
  description    String?
  customerId     Int?
  customerItemId Int?
  masterSpecId   Int?
  condition      ToolCondition
  locationId     Int
  fileUrl        String?
  fileName       String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer     Customer?     @relation(fields: [customerId], references: [id])
  customerItem CustomerItem? @relation(fields: [customerItemId], references: [id])
  masterSpec   MasterSpec?   @relation(fields: [masterSpecId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  blankSpecs   BlankSpec[]   @relation("BlankSpecDie")

  @@index([customerId])
  @@index([customerItemId])
  @@index([masterSpecId])
  @@index([type])
}

model ProductVariant {
  id                 Int      @id @default(autoincrement())
  masterSpecId       Int
  sku                String   @unique
  variantDescription String?
  boardGradeId       Int?
  flute              String?
  caliper            Decimal? @db.Decimal(6, 3)
  width              Decimal? @db.Decimal(8, 3)
  length             Decimal? @db.Decimal(8, 3)
  thickness          Decimal? @db.Decimal(8, 3)
  bundleQty          Int?
  caseQty            Int?
  listPrice          Decimal? @db.Decimal(12, 4)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  masterSpec             MasterSpec               @relation(fields: [masterSpecId], references: [id])
  boardGrade             BoardGrade?              @relation(fields: [boardGradeId], references: [id])
  blankSpec              BlankSpec?               @relation("VariantBlankSpec")
  bomLines               BOMLine[]
  variantSpecs           VariantSpec[]
  specs                  ProductSpec[]
  quoteItems             QuoteItem[]
  orderItems             SalesOrderItem[]
  shipmentItems          ShipmentItem[]
  finishedGoodsInventory FinishedGoodsInventory[]
  customerItems          CustomerItem[]
  inventoryCommitments   InventoryCommitment[]

  @@index([masterSpecId])
  @@index([boardGradeId])
}

model VariantSpec {
  id          Int      @id @default(autoincrement())
  variantId   Int
  specFieldId Int
  value       String
  createdAt   DateTime @default(now())

  variant   ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  specField ModuleSpecField @relation(fields: [specFieldId], references: [id])

  @@unique([variantId, specFieldId])
}

model ProductSpec {
  id           Int     @id @default(autoincrement())
  masterSpecId Int
  variantId    Int?
  specKey      String
  specValue    String
  specUnit     String?
  sortOrder    Int?

  masterSpec MasterSpec      @relation(fields: [masterSpecId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([masterSpecId])
}

model FinishedGoodsInventory {
  id           Int      @id @default(autoincrement())
  masterSpecId Int
  variantId    Int?
  locationId   Int
  quantity     Decimal  @default(0) @db.Decimal(14, 4)
  avgCost      Decimal? @db.Decimal(12, 4)
  updatedAt    DateTime @updatedAt

  masterSpec MasterSpec      @relation(fields: [masterSpecId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  location   Location        @relation(fields: [locationId], references: [id])

  @@index([masterSpecId])
  @@index([locationId])
}

model InventoryTransfer {
  id              Int            @id @default(autoincrement())
  materialId      Int?
  masterSpecId    Int?
  variantId       Int?
  fromLocationId  Int
  toLocationId    Int
  quantity        Decimal        @db.Decimal(14, 4)
  transferredById Int
  transferredAt   DateTime
  notes           String?
  status          TransferStatus @default(PENDING)

  material        Material?        @relation(fields: [materialId],       references: [id])
  masterSpec      MasterSpec?      @relation(fields: [masterSpecId],     references: [id])
  materialVariant MaterialVariant? @relation(fields: [variantId],        references: [id])
  fromLocation    Location         @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation      Location         @relation("TransferTo",   fields: [toLocationId],   references: [id])
  transferredBy   User             @relation(fields: [transferredById],  references: [id])

  @@index([materialId])
  @@index([masterSpecId])
  @@index([fromLocationId])
  @@index([toLocationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTING
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id          Int         @id @default(autoincrement())
  quoteNumber String      @unique
  customerId  Int
  createdById Int
  status      QuoteStatus @default(DRAFT)
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer  Customer    @relation(fields: [customerId],  references: [id])
  createdBy User        @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  items     QuoteItem[]
  order     SalesOrder?

  @@index([customerId])
  @@index([status])
}

model QuoteItem {
  id             Int     @id @default(autoincrement())
  quoteId        Int
  customerItemId Int?
  variantId      Int?
  lineNumber     Int
  description    String
  quantity       Int
  unitPrice      Decimal @db.Decimal(12, 4)
  notes          String?

  quote        Quote              @relation(fields: [quoteId],        references: [id], onDelete: Cascade)
  customerItem CustomerItem?      @relation(fields: [customerItemId], references: [id])
  variant      ProductVariant?    @relation(fields: [variantId],      references: [id])
  boxSpec      BoxSpec?           @relation("QuoteItemBoxSpec")
  blankSpec    BlankSpec?         @relation("QuoteItemBlankSpec")
  bomLines     QuoteItemBOMLine[]
  orderItems   SalesOrderItem[]

  @@unique([quoteId, lineNumber])
  @@index([quoteId])
}

model QuoteItemBOMLine {
  id          Int     @id @default(autoincrement())
  quoteItemId Int
  materialId  Int
  quantityPer Decimal @db.Decimal(14, 6)
  unitCost    Decimal @db.Decimal(12, 4)

  quoteItem QuoteItem @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)
  material  Material  @relation(fields: [materialId],  references: [id])

  @@unique([quoteItemId, materialId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SALES ORDERS
// ─────────────────────────────────────────────────────────────────────────────

model SalesOrder {
  id                 Int         @id @default(autoincrement())
  orderNumber        String      @unique
  quoteId            Int?        @unique
  customerId         Int
  createdById        Int
  status             OrderStatus @default(OPEN)
  orderDate          DateTime    @default(now())
  requestedShipDate  DateTime?
  customerPONumber   String?
  customerPODate     DateTime?
  customerPODocument String?
  overTolerance      Decimal?    @db.Decimal(6, 2)
  underTolerance     Decimal?    @db.Decimal(6, 2)
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  quote     Quote?          @relation(fields: [quoteId],     references: [id])
  customer  Customer        @relation(fields: [customerId],  references: [id])
  createdBy User            @relation("OrderCreatedBy", fields: [createdById], references: [id])
  items     SalesOrderItem[]
  shipments Shipment[]
  invoices  Invoice[]

  @@index([customerId])
  @@index([status])
}

model SalesOrderItem {
  id                Int      @id @default(autoincrement())
  orderId           Int
  quoteItemId       Int?
  customerItemId    Int?
  variantId         Int?
  lineNumber        Int
  description       String
  quantity          Int
  unitPrice         Decimal  @db.Decimal(12, 4)
  qtyShipped        Int      @default(0)
  toleranceOverride Boolean  @default(false)
  qtyTolerance      Decimal? @db.Decimal(6, 2)

  order                SalesOrder           @relation(fields: [orderId],         references: [id], onDelete: Cascade)
  quoteItem            QuoteItem?           @relation(fields: [quoteItemId],     references: [id])
  customerItem         CustomerItem?        @relation(fields: [customerItemId],  references: [id])
  variant              ProductVariant?      @relation(fields: [variantId],       references: [id])
  jobs                 ProductionJob[]
  shipmentItems        ShipmentItem[]
  inventoryCommitments InventoryCommitment[]

  @@unique([orderId, lineNumber])
  @@index([orderId])
}

model InventoryCommitment {
  id           Int              @id @default(autoincrement())
  orderItemId  Int
  masterSpecId Int?
  variantId    Int?
  locationId   Int
  quantity     Decimal          @db.Decimal(14, 4)
  status       CommitmentStatus @default(PENDING)
  committedAt  DateTime         @default(now())
  releasedAt   DateTime?
  notes        String?

  orderItem  SalesOrderItem  @relation(fields: [orderItemId],  references: [id])
  masterSpec MasterSpec?     @relation(fields: [masterSpecId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId],    references: [id])
  location   Location        @relation(fields: [locationId],   references: [id])

  @@index([orderItemId])
  @@index([masterSpecId])
  @@index([locationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTION
// ─────────────────────────────────────────────────────────────────────────────

model ProductionJob {
  id                    Int          @id @default(autoincrement())
  jobNumber             String       @unique
  orderItemId           Int
  resourceId            Int
  locationId            Int
  sequence              Int
  status                JobStatus    @default(QUEUED)
  jobReadiness          JobReadiness @default(READY)
  sheetsConfirmed       Boolean      @default(false)
  toolingConfirmed      Boolean      @default(false)
  scheduledDate         DateTime?
  completedDate         DateTime?
  quantityOrdered       Int
  quantityComplete      Int          @default(0)
  quantityGoodOutput    Int          @default(0)
  quantityWaste         Int          @default(0)
  wasteQty              Int          @default(0)
  rawMaterialConsumed   Decimal      @default(0) @db.Decimal(14, 4)
  finishedGoodsProduced Int          @default(0)
  estimatedSetupMinutes Int?
  actualSetupMinutes    Int?
  estimatedRunMinutes   Int?
  actualRunMinutes      Int?
  plateNumber           String?
  dieNumber             String?
  notes                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  orderItem    SalesOrderItem        @relation(fields: [orderItemId], references: [id])
  resource     Resource              @relation(fields: [resourceId],  references: [id])
  location     Location              @relation(fields: [locationId],  references: [id])
  consumptions ProductionConsumption[]

  @@index([status])
  @@index([resourceId])
  @@index([scheduledDate])
}

model ProductionConsumption {
  id                   Int      @id @default(autoincrement())
  productionJobId      Int
  materialId           Int
  variantId            Int?
  locationId           Int
  quantityIssued       Decimal  @db.Decimal(14, 4)
  quantityActuallyUsed Decimal  @db.Decimal(14, 4)
  quantityReturned     Decimal  @default(0) @db.Decimal(14, 4)
  wasteQuantity        Decimal  @default(0) @db.Decimal(14, 4)
  consumedAt           DateTime
  consumedById         Int

  productionJob   ProductionJob    @relation(fields: [productionJobId], references: [id])
  material        Material         @relation(fields: [materialId],      references: [id])
  materialVariant MaterialVariant? @relation(fields: [variantId],       references: [id])
  location        Location         @relation(fields: [locationId],      references: [id])
  consumedBy      User             @relation(fields: [consumedById],    references: [id])

  @@index([productionJobId])
  @@index([materialId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SHIPPING
// ─────────────────────────────────────────────────────────────────────────────

model Shipment {
  id                  Int            @id @default(autoincrement())
  shipmentNumber      String         @unique
  orderId             Int
  locationId          Int
  status              ShipmentStatus @default(PENDING)
  shipmentStage       ShipmentStage  @default(DRAFT)
  carrier             String?
  trackingNumber      String?
  bolNumber           String?
  totalWeight         Decimal?       @db.Decimal(10, 2)
  palletCount         Int?
  systemSuggestedQty  Decimal?       @db.Decimal(14, 4)
  warehouseEnteredQty Decimal?       @db.Decimal(14, 4)
  confirmedQty        Decimal?       @db.Decimal(14, 4)
  confirmedById       Int?
  confirmedAt         DateTime?
  varianceQty         Decimal?       @db.Decimal(14, 4)
  varianceReason      VarianceReason?
  shippedAt           DateTime?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  order       SalesOrder    @relation(fields: [orderId],      references: [id])
  location    Location      @relation(fields: [locationId],   references: [id])
  confirmedBy User?         @relation("ShipmentConfirmedBy", fields: [confirmedById], references: [id])
  items       ShipmentItem[]
  invoices    Invoice[]

  @@index([orderId])
  @@index([status])
}

model ShipmentItem {
  id                  Int      @id @default(autoincrement())
  shipmentId          Int
  orderItemId         Int
  variantId           Int?
  quantity            Int
  systemSuggestedQty  Decimal? @db.Decimal(14, 4)
  warehouseEnteredQty Decimal? @db.Decimal(14, 4)
  confirmedQty        Decimal? @db.Decimal(14, 4)
  varianceNotes       String?

  shipment  Shipment        @relation(fields: [shipmentId],  references: [id], onDelete: Cascade)
  orderItem SalesOrderItem  @relation(fields: [orderItemId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId],   references: [id])

  @@unique([shipmentId, orderItemId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICING
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  orderId       Int
  shipmentId    Int?
  customerId    Int
  status        InvoiceStatus @default(DRAFT)
  invoiceDate   DateTime
  dueDate       DateTime
  totalAmount   Decimal       @db.Decimal(12, 2)
  qbSyncStatus  QbSyncStatus  @default(NOT_SYNCED)
  qbSyncedAt    DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order    SalesOrder @relation(fields: [orderId],    references: [id])
  shipment Shipment?  @relation(fields: [shipmentId], references: [id])
  customer Customer   @relation(fields: [customerId], references: [id])

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([qbSyncStatus])
}
